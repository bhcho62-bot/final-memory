        if (isRecording) {
            recognition.start();
            document.getElementById('mic-btn').classList.add('recording');
        } else {
            recognition.stop();
            document.getElementById('mic-btn').classList.remove('recording');
        }
    }

    function showScreen(id) {
        ["step-setup", "step-ready", "step-speak", "step-input", "step-wait", "step-result"].forEach(s => document.getElementById(s).classList.add('hidden'));
        document.getElementById(id).classList.remove('hidden');
    }

    function pressStart() {
        synth.speak(new SpeechSynthesisUtterance(""));
        config.count = parseInt(document.getElementById('wCount').value);
        config.delay = parseInt(document.getElementById('dTime').value);

        if(currentRound === 1) {
            targetWords = [...wordDB].sort(() => Math.random() - 0.5).slice(0, config.count);
            roundScores = [];
        }

        showScreen('step-ready');
        let c = 3;
        const cd = document.getElementById('countdown');
        cd.innerText = c;
        const timer = setInterval(() => {
            c--; cd.innerText = c;
            if(c <= 0) { clearInterval(timer); startTTS(); }
        }, 1000);
    }

    function startTTS() {
        showScreen('step-speak');
        let idx = 0;
        function speak() {
            if(idx < targetWords.length) {
                document.getElementById('speak-idx').innerText = `${idx + 1} / ${targetWords.length}`;
                const msg = new SpeechSynthesisUtterance(targetWords[idx]);
                msg.lang = 'ko-KR';
                msg.volume = config.vol;
                msg.rate = 0.95;
                // 단어 간 간격을 1초(1000ms)로 연장
                msg.onend = () => { idx++; setTimeout(speak, 1000); };
                synth.speak(msg);
            } else { goToInputPhase(); }
        }
        speak();
    }

    function goToInputPhase() {
        showScreen('step-input');
        document.getElementById('u-input').value = "";
        wordCountSTT = 0;
        document.getElementById('stt-visualizer').innerText = "● 인식 중...";
        document.getElementById('input-title').innerText = (currentRound <= 3) ? `${currentRound}회차 회상` : `최종 장기기억 테스트`;
    }

    function pressNext() {
        isRecording = false;
        if(recognition) recognition.stop();
        document.getElementById('mic-btn').classList.remove('recording');

        const input = document.getElementById('u-input').value;
        const userWords = input.split(/[\s,.\n]+/).filter(w => w.length > 0);
        let s = 0;
        targetWords.forEach(tw => {
            if(userWords.some(uw => uw.includes(tw) || tw.includes(uw))) s++;
        });

        if (currentRound <= 3) {
            roundScores.push(s);
            if (currentRound < 3) { currentRound++; pressStart(); }
            else { currentRound = 4; startWaitingMode(); }
        } else { finishTraining(s); }
    }

    function startWaitingMode() {
        showScreen('step-wait');
        let tl = config.delay;
        const update = () => {
            let m = Math.floor(tl / 60), s = tl % 60;
            document.getElementById('wait-timer').innerText = `${m}:${s.toString().padStart(2,'0')}`;
            if(tl <= 0) { clearInterval(waitInterval); goToInputPhase(); }
            tl--;
        };
        update();
        waitInterval = setInterval(update, 1000);
    }

    function skipWait() { clearInterval(waitInterval); goToInputPhase(); }

    function finishTraining(finalScore) {
        const now = new Date();
        const dateStr = `${now.getMonth()+1}/${now.getDate()} ${now.getHours()}:${now.getMinutes().toString().padStart(2,'0')}`;
        history.unshift({ date: dateStr, scores: [...roundScores], final: finalScore, total: targetWords.length });
        if(history.length > 30) history.pop();
        localStorage.setItem('memoryTrainHistory', JSON.stringify(history));

        let sumHtml = `<strong>📊 결과 (${targetWords.length}단어 모드)</strong><br>`;
        roundScores.forEach((s, i) => { sumHtml += `${i+1}회: ${s}개 / `; });
        sumHtml += `<span style="color:#2b8a3e; font-weight:bold;">최종: ${finalScore}개</span>`;

        let ansHtml = "<strong>✅ 정답 대조 (최종 결과에서만 공개)</strong><br>";
        const lastInput = document.getElementById('u-input').value;
        targetWords.forEach(tw => {
            if(lastInput.includes(tw)) ansHtml += `<span style="color:green; font-weight:bold;">✔${tw}</span> `;
            else ansHtml += `<span style="color:#e03131; text-decoration:line-through; opacity:0.5;">✘${tw}</span> `;
        });

        showScreen('step-result');
        document.getElementById('round-scores').innerHTML = sumHtml;
        document.getElementById('answer-list').innerHTML = ansHtml;
        renderHistory();
    }
</script>
