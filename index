        showScreen('step-recognition');
        selectedRecogWords = [];
        let distractors = wordDB.filter(w => !targetWords.includes(w)).sort(() => Math.random() - 0.5).slice(0, 24 - targetWords.length);
        let pool = [...targetWords, ...distractors].sort(() => Math.random() - 0.5);
        const poolEl = document.getElementById('word-pool');
        poolEl.innerHTML = "";
        pool.forEach(word => {
            const tile = document.createElement('div');
            tile.className = 'word-tile';
            tile.innerText = word;
            tile.onclick = () => {
                tile.classList.toggle('selected');
                if(tile.classList.contains('selected')) selectedRecogWords.push(word);
                else selectedRecogWords = selectedRecogWords.filter(w => w !== word);
            };
            poolEl.appendChild(tile);
        });
    }

    function submitRecognition() {
        let correctPick = 0;
        selectedRecogWords.forEach(w => { if(targetWords.includes(w)) correctPick++; });
        finishTraining(recognitionScore, correctPick);
    }

    function finishTraining(longTermScore, recogScore) {
        let sumHtml = "<strong>📊 훈련 데이터 요약</strong><br>";
        roundScores.forEach((s, i) => { sumHtml += `${i+1}회차: ${s} / ${targetWords.length}<br>`; });
        sumHtml += `<br><span style="color:#228be6;">장기 기억 회상: ${longTermScore} / ${targetWords.length}</span><br>`;
        sumHtml += `<span style="color:#40c057;">단어 고르기: ${recogScore} / ${targetWords.length}</span>`;
        let ansHtml = "<strong>🎯 이번 훈련 정답 단어들</strong><br>";
        targetWords.forEach(tw => { ansHtml += `<span>${tw}</span> `; });
        showScreen('step-result');
        document.getElementById('round-scores').innerHTML = sumHtml;
        document.getElementById('answer-list').innerHTML = ansHtml;
        const now = new Date();
        const record = { date: `${now.getMonth()+1}/${now.getDate()}`, scores: [...roundScores], final: longTermScore, total: targetWords.length };
        history.unshift(record);
        localStorage.setItem('memoryTrainHistory', JSON.stringify(history.slice(0, 50)));
        renderHistoryList();
    }

    function startWaitingMode() {
        showScreen('step-wait');
        let tl = config.delay;
        waitInterval = setInterval(() => {
            let m = Math.floor(tl / 60), s = tl % 60;
            document.getElementById('wait-timer').innerText = `${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
            if(tl <= 0) { clearInterval(waitInterval); goToInputPhase(); }
            tl--;
        }, 1000);
    }
    function skipWait() { clearInterval(waitInterval); goToInputPhase(); }
    function updateVol(v) { config.vol = parseFloat(v); }
    function renderHistoryList() {
        const listEl = document.getElementById('main-history-list');
        if(history.length === 0) { listEl.innerHTML = "<div style='padding:10px; color:#999;'>기록 없음</div>"; return; }
        listEl.innerHTML = history.map(h => `<div class="history-item"><div>${h.date}</div><div>${h.scores.join('→')} (최종:${h.final})</div></div>`).join('');
    }
    window.onload = () => { history = JSON.parse(localStorage.getItem('memoryTrainHistory') || "[]"); renderHistoryList(); };

    if (Recognition) {
        recognition = new Recognition(); recognition.lang = 'ko-KR'; recognition.continuous = true;
        recognition.onresult = (e) => { document.getElementById('u-input').value += e.results[e.results.length - 1][0].transcript + " "; };
        recognition.onend = () => { if(isRecording) recognition.start(); };
    }
    function toggleMic() {
        if (!recognition) return alert("지원불가 브라우저");
        isRecording = !isRecording;
        const btn = document.getElementById('mic-btn');
        if (isRecording) { recognition.start(); btn.classList.add('recording'); btn.innerText = "🎙️ 듣고 있습니다..."; } 
        else { recognition.stop(); btn.classList.remove('recording'); btn.innerText = "🎤 음성 인식 시작"; }
    }
</script>
