<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>암기력 훈련 v6.3 (모바일 최적화)</title>
    <style>
        body { font-family: 'Pretendard', -apple-system, sans-serif; background: #f0f2f5; display: flex; justify-content: center; padding: 20px; margin: 0; }
        #app { background: white; width: 100%; max-width: 600px; padding: 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); text-align: center; box-sizing: border-box; }
        .hidden { display: none !important; }
        .panel { background: #f8f9fa; padding: 15px; border-radius: 10px; margin-bottom: 15px; text-align: left; }
        #countdown { font-size: 8rem; color: #228be6; font-weight: bold; margin: 30px 0; }
        button { width: 100%; padding: 18px; font-size: 1.1rem; border: none; border-radius: 10px; cursor: pointer; font-weight: bold; background: #228be6; color: white; transition: 0.2s; }
        .btn-mic { background: #f03e3e; min-height: 120px; width: 100%; margin-bottom: 15px; border-radius: 15px; position: relative; }
        .btn-mic.recording { background: #ff922b; animation: pulse 1.5s infinite; }
        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.7; } 100% { opacity: 1; } }
        #security-box { width: 100%; height: 60px; margin-top: 10px; background: #e9ecef; border: 2px dashed #ced4da; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #495057; font-weight: bold; font-size: 0.9rem; }
        .recog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 20px; }
        .recog-item { padding: 15px 5px; background: #fff; border: 2px solid #dee2e6; border-radius: 10px; cursor: pointer; font-weight: bold; font-size: 0.9rem; }
        .recog-item.selected { background: #e7f5ff; border-color: #228be6; color: #228be6; }
        .ans-check { display: inline-block; margin: 5px; padding: 5px 12px; border-radius: 8px; font-weight: bold; border: 1px solid #ddd; }
        .hit { background: #e6ffed; color: #22863a; border-color: #34d058; }
        .miss { background: #ffeef0; color: #cb2431; border-color: #f97583; }
    </style>
</head>
<body>

<div id="app" onclick="activateAudio()">
    <div id="step-setup">
        <h2>🧠 암기력 훈련 v6.3</h2>
        <p style="font-size:0.8rem; color:#888;">모바일은 화면을 한 번 터치 후 시작하세요.</p>
        <div class="panel">
            <label>🎯 단어 수</label>
            <select id="wCount" style="width:100%; padding:12px; margin:10px 0;">
                <option value="5">입문 (5개)</option>
                <option value="12" selected>보통 (12개)</option>
                <option value="15">집중 (15개)</option>
            </select>
            <label>⏳ 지연 시간</label>
            <select id="dTime" style="width:100%; padding:12px; margin:10px 0;">
                <option value="5">5초 (테스트용)</option>
                <option value="1200" selected>20분 (표준)</option>
            </select>
        </div>
        <button onclick="pressStart()">훈련 시작</button>
    </div>

    <div id="step-ready" class="hidden"><div id="countdown">3</div></div>

    <div id="step-speak" class="hidden">
        <h2 id="speak-idx" style="color:#e03131;">1 / 12</h2>
        <div style="font-size: 5rem; margin: 20px;">📢</div>
        <p>단어를 잘 듣고 암기하세요.</p>
    </div>

    <div id="step-input" class="hidden">
        <h3 id="input-title">회상 단계</h3>
        <button id="mic-btn" class="btn-mic" onclick="toggleMicManually()">
            <span id="mic-text" style="font-size:1.2rem;">🎤 음성 인식 시작</span>
            <div id="stt-count" style="font-size:1rem; margin-top:10px; font-weight: bold; color: yellow;"></div>
        </button>
        <div id="security-box">🔒 보안: 입력 단어 비표시 모드</div>
        <button style="background:#40c057; width:100%; margin-top:15px;" onclick="pressNext()">모두 말했습니다 (완료)</button>
    </div>

    <div id="step-wait" class="hidden">
        <p>기억 고정 대기 중...</p>
        <div id="wait-timer" style="font-size: 4rem; font-weight: bold; color: #228be6;">00:00</div>
        <button onclick="skipWait()" style="background:#868e96; width:100%;">건너뛰기</button>
    </div>

    <div id="step-recog" class="hidden">
        <h3>✅ 재인 검사</h3>
        <p>학습한 단어를 모두 선택하세요.</p>
        <div id="recog-grid" class="recog-grid"></div>
        <button style="margin-top:20px; width:100%; background:#40c057;" onclick="finishTraining()">결과 확인</button>
    </div>

    <div id="step-result" class="hidden">
        <h2>📊 분석 결과</h2>
        <div id="round-scores" class="panel" style="line-height:2; font-size:1.1rem;"></div>
        <div class="panel">
            <h4>✅ 정답 대조표</h4>
            <div id="answer-grid" style="text-align: left;"></div>
        </div>
        <button onclick="location.reload()" style="width:100%;">처음으로</button>
    </div>
</div>

<script>
    const wordDB = ["사과", "우주", "기타", "강아지", "비행기", "시계", "축구", "모자", "고래", "연필", "구름", "자전거", "커피", "나무", "사진", "신발", "우산", "전화", "의자", "책상", "창문", "침대", "치약", "비누", "수건", "접시", "가위", "로봇", "풍선", "계단", "기차", "버스", "포크", "냄비", "지도", "거울", "안경", "지갑", "열쇠", "가방", "우유", "라면", "포도", "수박", "오이", "감자", "계란", "치즈", "사탕", "보리", "사자", "호랑이", "코끼리", "기린", "토끼", "곰", "장미", "나비", "개미", "별", "달", "태양", "지구", "산", "강", "바다", "숲", "바람", "무지개", "파도", "번개", "안개", "낙엽", "뿌리", "줄기", "파리", "모기", "참새", "까치", "독수리", "상어", "거북이", "문어", "조개", "고추", "마늘", "배추", "양파", "버섯", "단풍", "눈사람", "태풍", "들판", "동굴", "계곡", "호수", "모래", "조약돌", "먼지", "소금"];

    let targetWords = [], currentRound = 1, roundScores = [], delayedScore = 0;
    let recogWords = [], selectedRecog = [], isAudioActive = false;
    let recognition, isRecording = false, waitTimer;
    let hiddenInputText = ""; 

    function activateAudio() {
        if (!isAudioActive) {
            window.speechSynthesis.speak(new SpeechSynthesisUtterance(""));
            isAudioActive = true;
        }
    }

    const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (SpeechRec) {
        recognition = new SpeechRec();
        recognition.lang = 'ko-KR';
        recognition.continuous = true;
        recognition.interimResults = false;

        recognition.onresult = (e) => {
            const res = e.results[e.results.length - 1][0].transcript;
            hiddenInputText += res + " ";
            updateCountDisplay();
        };

        // 모바일 핵심 수정: 인식이 끊기면 다시 시작하도록 함
        recognition.onend = () => {
            if (isRecording) {
                recognition.start(); // 강제 재시작
            }
        };

        recognition.onerror = (e) => {
            console.error("STT Error:", e.error);
            if(e.error === 'network') alert("네트워크 연결을 확인하세요.");
        };
    }

    function updateCountDisplay() {
        const words = hiddenInputText.trim().split(/\s+/).filter(w => w.length > 0);
        document.getElementById('stt-count').innerText = `● 현재 ${words.length}개 단어 인식됨`;
    }

    function showScreen(id) {
        ["step-setup", "step-ready", "step-speak", "step-input", "step-wait", "step-recog", "step-result"].forEach(s => document.getElementById(s).classList.add('hidden'));
        document.getElementById(id).classList.remove('hidden');
    }

    function pressStart() {
        activateAudio();
        if(currentRound === 1) {
            const count = parseInt(document.getElementById('wCount').value);
            targetWords = [...wordDB].sort(() => Math.random() - 0.5).slice(0, count);
            roundScores = [];
        }
        showScreen('step-ready');
        let c = 3;
        const timer = setInterval(() => {
            document.getElementById('countdown').innerText = c;
            if(c-- <= 0) { clearInterval(timer); startTTS(); }
        }, 1000);
    }

    function startTTS() {
        showScreen('step-speak');
        let idx = 0;
        function speak() {
            if(idx < targetWords.length) {
                document.getElementById('speak-idx').innerText = `${idx + 1} / ${targetWords.length}`;
                const msg = new SpeechSynthesisUtterance(targetWords[idx]);
                msg.lang = 'ko-KR';
                msg.onend = () => { idx++; setTimeout(speak, 1000); };
                window.speechSynthesis.speak(msg);
            } else { 
                showScreen('step-input'); 
                hiddenInputText = ""; 
                updateCountDisplay();
            }
        }
        speak();
    }

    function toggleMicManually() {
        if(!recognition) return alert("음성 인식을 지원하지 않는 기기입니다.");
        
        if(!isRecording) {
            isRecording = true;
            recognition.start();
            document.getElementById('mic-btn').classList.add('recording');
            document.getElementById('mic-text').innerText = "듣고 있습니다... (연속 입력 가능)";
        } else {
            isRecording = false;
            recognition.stop();
            document.getElementById('mic-btn').classList.remove('recording');
            document.getElementById('mic-text').innerText = "🎤 음성 인식 시작";
        }
    }

    function pressNext() {
        isRecording = false; // 자동 재시작 방지
        recognition.stop();
        document.getElementById('mic-btn').classList.remove('recording');
        document.getElementById('mic-text').innerText = "🎤 음성 인식 시작";

        let s = 0;
        targetWords.forEach(w => { if(hiddenInputText.includes(w)) s++; });

        if(currentRound <= 3) {
            roundScores.push(s);
            if(currentRound < 3) { currentRound++; pressStart(); }
            else { currentRound = 4; startWait(); }
        } else {
            delayedScore = s;
            startRecogPhase();
        }
    }

    function startWait() {
        showScreen('step-wait');
        let t = parseInt(document.getElementById('dTime').value);
        waitTimer = setInterval(() => {
            document.getElementById('wait-timer').innerText = `${Math.floor(t/60)}:${(t%60).toString().padStart(2,'0')}`;
            if(t-- <= 0) { clearInterval(waitTimer); showScreen('step-input'); hiddenInputText = ""; updateCountDisplay(); }
        }, 1000);
    }

    function skipWait() { clearInterval(waitTimer); showScreen('step-input'); hiddenInputText = ""; updateCountDisplay(); }

    function startRecogPhase() {
        showScreen('step-recog');
        selectedRecog = [];
        const others = wordDB.filter(w => !targetWords.includes(w)).sort(() => Math.random() - 0.5).slice(0, 24 - targetWords.length);
        recogWords = [...targetWords, ...others].sort(() => Math.random() - 0.5);
        const grid = document.getElementById('recog-grid');
        grid.innerHTML = recogWords.map((w, i) => `<div class="recog-item" id="rec-${i}" onclick="toggleRec(${i})">${w}</div>`).join('');
    }

    function toggleRec(i) {
        const w = recogWords[i];
        const el = document.getElementById(`rec-${i}`);
        if(selectedRecog.includes(w)) {
            selectedRecog = selectedRecog.filter(x => x !== w);
            el.classList.remove('selected');
        } else {
            selectedRecog.push(w);
            el.classList.add('selected');
        }
    }

    function finishTraining() {
        let rScore = 0;
        selectedRecog.forEach(w => { if(targetWords.includes(w)) rScore++; });
        showScreen('step-result');
        document.getElementById('round-scores').innerHTML = `
            즉시 회상 (1~3회차): ${roundScores.join(' → ')} <br>
            지연 회상 점수: <b>${delayedScore}개</b> <br>
            재인 검사 점수: <b>${rScore} / ${targetWords.length}</b>
        `;
        document.getElementById('answer-grid').innerHTML = targetWords.map(w => {
            const isHit = selectedRecog.includes(w);
            return `<div class="ans-check ${isHit ? 'hit' : 'miss'}">${isHit ? '✔' : '✘'} ${w}</div>`;
        }).join('');
    }
</script>
</body>
</html>
