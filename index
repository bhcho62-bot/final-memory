    let recognition, isRecording = false, waitInterval = null, wordCountSTT = 0;

    window.onload = () => { loadHistory(); };

    function loadHistory() {
        history = JSON.parse(localStorage.getItem('memoryTrainHistory') || "[]");
        renderHistory();
    }

    function renderHistory() {
        const list = document.getElementById('main-history-list');
        list.innerHTML = history.length ? history.map(item => `
            <div class="history-item">
                <span>${item.date}</span>
                <span><b>${item.scores.join('→')}</b> (최종:${item.final}/${item.total})</span>
            </div>
        `).join('') : '<div style="padding:15px; color:#999;">기록 없음</div>';
    }

    function updateVol(v) { config.vol = parseFloat(v); }

    if (Recognition) {
        recognition = new Recognition();
        recognition.lang = 'ko-KR';
        recognition.continuous = true;
        recognition.onstart = () => {
            document.getElementById('mic-text').innerText = "음성을 듣고 있습니다";
            document.getElementById('stt-visualizer').classList.remove('hidden');
        };
        recognition.onresult = (e) => {
            const res = e.results[e.results.length - 1][0].transcript;
            document.getElementById('u-input').value += res + " ";
            wordCountSTT = document.getElementById('u-input').value.trim().split(/\s+/).length;
            // 텍스트는 보여주지 않고 카운트만 업데이트
            document.getElementById('stt-visualizer').innerText = `● 현재 ${wordCountSTT}개 단어 인식됨`;
        };
        recognition.onend = () => {
            if(isRecording) recognition.start();
            else {
                document.getElementById('mic-text').innerText = "음성 인식 시작";
                document.getElementById('stt-visualizer').classList.add('hidden');
            }
        };
    }

